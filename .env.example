# New Touch of Color — Estimator Platform
# The prototype runs WITHOUT any environment variables (all data is mocked).
# Copy this file to `.env.local` when you start wiring a real backend in Replit.
#
# Vite only exposes variables prefixed with VITE_ to the client.

# --- Backend API (to be wired in Replit) ---
# VITE_API_URL=https://api.example.com

# --- Auth provider (replace mock auth in src/lib/auth.tsx) ---
# VITE_AUTH_DOMAIN=auth.example.com
# VITE_AUTH_CLIENT_ID=

# --- Optional integrations ---
# VITE_QUICKBOOKS_CLIENT_ID=
# VITE_DOCUSIGN_CLIENT_ID=
